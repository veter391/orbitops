# Copy to .env for local overrides. Sane defaults ship in src/config.ts.
HOST=127.0.0.1
PORT=8790
DATA_DIR=./.data/pgdata
LOG_LEVEL=info
NODE_ENV=development

# Security. CORS_ORIGINS empty = same-origin only; set a comma-separated allow-list in prod.
CORS_ORIGINS=
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
BODY_LIMIT=1048576
# Signs the audit chain. REQUIRED in production (boot fails if unset/weak/default):
# generate with `openssl rand -hex 32`. The dev default below is for local only.
AUDIT_HMAC_KEY=dev-insecure-key-change-me

# Optional: LLM augmentation for the agent's "think" step. Leave unset to run the
# agent fully deterministic and offline (no network). The reasoning chain is the
# source of truth regardless.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
