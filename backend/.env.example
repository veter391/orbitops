# Copy to .env for local overrides. Sane defaults ship in src/config.ts, so an
# empty .env boots a working dev server on local pglite with the deterministic
# agent (no API keys, no cloud). Override only what you need.
#
# Secrets: never commit real values. In production prefer file-based secrets via
# `<NAME>_FILE=/run/secrets/...` over inline env — see docs/INFRA.md.

# ── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8790
LOG_LEVEL=info
NODE_ENV=development

# Security. CORS_ORIGINS empty = same-origin only; set a comma-separated allow-list in prod.
CORS_ORIGINS=
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
BODY_LIMIT=1048576

# ── Database ────────────────────────────────────────────────────────────────
# Local pglite data dir (dev default). Ignored when DATABASE_URL is set.
DATA_DIR=./.data/pgdata
# Set to a managed Postgres in production (enables the real pg driver).
# DATABASE_URL=postgres://user:pass@host:5432/orbitops
# Enforce Row-Level Security (DB-layer tenant isolation). Requires a NON-superuser
# Postgres role — superusers bypass RLS. Leave false on dev/pglite. See docs/INFRA.md.
DB_RLS=false

# ── Telemetry / observability ───────────────────────────────────────────────
# OTLP span export endpoint, e.g. http://localhost:4318/v1/traces. Unset = off.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# Days of telemetry to retain; 0 = keep forever (purge loop disabled).
TELEMETRY_RETENTION_DAYS=0

# ── Agent ───────────────────────────────────────────────────────────────────
# Nominal delta-v envelope (m/s); the compliance critic flags burns above it.
AGENT_MAX_DELTA_V_MS=5
# Similarity (semantic) memory. On = offline lexical embedder (no key, no cost).
AGENT_SEMANTIC_MEMORY=false

# ── Secrets ─────────────────────────────────────────────────────────────────
# Signs the audit chain. REQUIRED in production: boot FAILS if this is unset, the
# dev default, or < 32 chars. Generate with `openssl rand -hex 32`.
AUDIT_HMAC_KEY=dev-insecure-key-change-me
# Keys short-lived WebSocket auth tickets. Falls back to AUDIT_HMAC_KEY when unset;
# set a DISTINCT value in production so the two blast radii stay independent.
# WS_TICKET_HMAC_KEY=

# ── Optional LLM augmentation (BYOK) ─────────────────────────────────────────
# With no key the agent runs a fully deterministic, offline loop. Provide a key to
# augment the "think" step; the reasoning chain stays the source of truth.
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
