{
  "name": "orbitops",
  "version": "0.1.0",
  "description": "AI co-pilot for commercial satellite constellation operators. Monitors, predicts, proposes — humans always in the loop.",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "dev": "python3 -m http.server 8080",
    "start": "python3 -m http.server 8080",
    "serve": "python3 -m http.server 8080",
    "lint": "eslint src/ worker.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,css,md}\" \"*.md\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{js,css,md}\" \"*.md\" \"docs/**/*.md\"",
    "test": "echo \"no tests yet — see CONTRIBUTING.md\" && exit 0",
    "cf:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "keywords": [
    "space",
    "satellite",
    "constellation",
    "operations",
    "ai",
    "ai-agent",
    "ssa",
    "space-situational-awareness",
    "collision-avoidance",
    "human-in-the-loop",
    "hitl",
    "three.js",
    "webgl",
    "open-source"
  ],
  "author": "OrbitOps contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.7.0"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14.5",
    "Edge >= 90"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orbitops/orbitops.git"
  },
  "bugs": {
    "url": "https://github.com/orbitops/orbitops/issues"
  },
  "homepage": "https://orbitops.io",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/orbitops"
  }
}